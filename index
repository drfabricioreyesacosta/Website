        <label class="triage-option" onclick="selectTriageOpt(this,'q3','health')"><div class="triage-option-dot"></div><span class="material-symbols-outlined" style="font-size:1.1rem;opacity:0.6;">favorite</span>Mejorar mi salud, energía y calidad de vida desde adentro</label>
        <label class="triage-option" onclick="selectTriageOpt(this,'q3','both')"><div class="triage-option-dot"></div><span class="material-symbols-outlined" style="font-size:1.1rem;opacity:0.6;">emoji_objects</span>Ambas son igual de importantes para mí</label>
      </div>
    </div>
    <div class="triage-nav">
      <button class="triage-btn-back" id="triage-back" onclick="triageBack()" style="visibility:hidden;">← Anterior</button>
      <button class="triage-btn-next" id="triage-next" onclick="triageNext()" disabled>Siguiente <span class="material-symbols-outlined" style="font-size:0.9rem;">arrow_forward</span></button>
    </div>
    <div id="triage-result">
      <div id="triage-result-title">Basado en tus respuestas, te recomendamos:</div>
      <div class="result-card" id="result-facelab" onclick="window.location='face-lab.html'">
        <span class="result-path">Path 01 · Medicina Estética</span>
        <div class="result-title">Face Lab</div>
        <div class="result-desc">Medicina estética de precisión. Bótox, rellenos, Endolift y bioestimuladores. Resultados concretos, enfoque científico.</div>
        <div class="result-cta">Explorar Face Lab <span class="material-symbols-outlined" style="font-size:0.9rem;">arrow_forward</span></div>
      </div>
      <div class="result-card" id="result-nexa" onclick="window.location='nexa-prime.html'">
        <span class="result-path">Path 02 · Salud Integral</span>
        <div class="result-title">Nexa Prime</div>
        <div class="result-desc">Programa médico de longevidad. Transformación integral con equipo multidisciplinario y seguimiento continuo.</div>
        <div class="result-cta">Explorar Nexa Prime <span class="material-symbols-outlined" style="font-size:0.9rem;">arrow_forward</span></div>
      </div>
      <p style="font-family:'Inter',sans-serif;font-size:0.7rem;color:#a9b4b7;margin-top:1rem;text-align:center;">También puedes explorar ambos caminos libremente.</p>
    </div>
  </div>
</div>

<!-- CHATBOT TRIGGER -->

<button id="chat-trigger" onclick="toggleChat()">
  <span class="material-symbols-outlined" id="trigger-icon">chat</span>
  <div id="chat-notif"></div>
</button>

<!-- CHAT WINDOW -->

<div id="chat-window">
  <div id="chat-header">
    <div class="chat-avatar"><span class="material-symbols-outlined">stethoscope</span></div>
    <div class="chat-header-info">
      <div class="chat-header-name">Dr. Alan Fabricio · Clínica</div>
      <div class="chat-header-status"><div class="status-dot"></div>Disponible ahora</div>
    </div>
    <button id="chat-close" onclick="toggleChat()"><span class="material-symbols-outlined" style="font-size:1.1rem;">close</span></button>
  </div>
  <div id="chat-messages"></div>
  <div id="chat-input-area">
    <input type="text" id="chat-input" placeholder="Escribe tu mensaje..." autocomplete="off" onkeydown="if(event.key==='Enter') sendUserMsg()"/>
    <button id="chat-send" onclick="sendUserMsg()"><span class="material-symbols-outlined">send</span></button>
  </div>
  <div class="chat-powered">Clinical Atelier · San Luis Río Colorado</div>
</div>

<script>
  // NAVBAR
  const navbar = document.getElementById('navbar');
  const cover  = document.getElementById('cover');
  const coverContent = document.getElementById('cover-content');
  const scrollHint   = document.getElementById('scroll-hint');
  const reveals = document.querySelectorAll('.reveal, .reveal-child');
  const triageBtn = document.getElementById('triage-btn');
  const pathsSection = document.getElementById('paths');

  function onScroll() {
    const sy = window.scrollY;
    const hh = cover.offsetHeight;
    const p  = Math.min(sy / hh, 1);
    coverContent.style.transform = 'translateY(' + (sy * 0.35) + 'px)';
    coverContent.style.opacity   = '' + (1 - p * 2.2);
    if (scrollHint) scrollHint.style.opacity = '' + (1 - p * 5);
    if (sy > hh * 0.7) {
      navbar.style.background = 'rgba(248,250,251,0.95)';
      navbar.style.boxShadow  = '0 1px 0 rgba(0,0,0,0.06)';
    } else {
      navbar.style.background = 'rgba(248,250,251,' + Math.min(p * 1.8, 0.92) + ')';
      navbar.style.boxShadow  = 'none';
    }
    // Triage button visibility
    if (pathsSection) {
      const pt = pathsSection.getBoundingClientRect().top;
      triageBtn.classList.toggle('visible', pt < window.innerHeight * 0.75);
    }
    // Reveal
    reveals.forEach(el => {
      if (el.getBoundingClientRect().top < window.innerHeight * 0.88) el.classList.add('visible');
    });
  }

  navbar.style.background = 'transparent';
  navbar.style.transition  = 'background 0.4s ease, box-shadow 0.3s ease';
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  document.getElementById('menu-toggle').addEventListener('click', () => {
    document.getElementById('mobile-menu').classList.toggle('open');
  });

  // TRIAGE
  const triageAnswers = { q1: null, q2: null, q3: null };
  let triageStep = 1;
  function openTriage() { document.getElementById('triage-overlay').classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeTriage() { document.getElementById('triage-overlay').classList.remove('open'); document.body.style.overflow = ''; }
  document.getElementById('triage-overlay').addEventListener('click', function(e) { if (e.target === this) closeTriage(); });
  function selectTriageOpt(label, question, value) {
    label.parentElement.querySelectorAll('.triage-option').forEach(o => o.classList.remove('selected'));
    label.classList.add('selected');
    triageAnswers[question] = value;
    document.getElementById('triage-next').disabled = false;
  }
  function triageNext() {
    if (triageStep < 3) { triageStep++; updateTriageUI(); }
    else showTriageResult();
  }
  function triageBack() { if (triageStep > 1) { triageStep--; updateTriageUI(); } }
  function updateTriageUI() {
    document.querySelectorAll('.triage-step').forEach(s => s.classList.remove('active'));
    document.getElementById('ts' + triageStep).classList.add('active');
    document.getElementById('triage-progress').style.width = (triageStep / 3 * 100) + '%';
    document.getElementById('triage-counter').textContent = 'Pregunta ' + triageStep + ' de 3';
    document.getElementById('triage-back').style.visibility = triageStep > 1 ? 'visible' : 'hidden';
    document.getElementById('triage-next').disabled = !triageAnswers['q' + triageStep];
  }
  function showTriageResult() {
    const vals = Object.values(triageAnswers);
    const appScore = vals.filter(v => v === 'appearance').length;
    const hlthScore = vals.filter(v => v === 'health').length;
    document.querySelector('.triage-body').style.display = 'none';
    document.querySelector('.triage-nav').style.display = 'none';
    document.getElementById('triage-counter').style.display = 'none';
    document.getElementById('triage-progress').style.width = '100%';
    document.getElementById('triage-result').style.display = 'block';
    const fl = document.getElementById('result-facelab');
    const nx = document.getElementById('result-nexa');
    fl.querySelectorAll('.result-badge').forEach(b => b.remove());
    nx.querySelectorAll('.result-badge').forEach(b => b.remove());
    fl.classList.remove('recommended'); nx.classList.remove('recommended');
    if (appScore > hlthScore) {
      fl.classList.add('recommended'); fl.insertAdjacentHTML('afterbegin','<span class="result-badge">✦ Recomendado para ti</span>');
      document.getElementById('triage-result-title').textContent = 'Face Lab es tu camino ideal.';
    } else if (hlthScore > appScore) {
      nx.classList.add('recommended'); nx.insertAdjacentHTML('afterbegin','<span class="result-badge">✦ Recomendado para ti</span>');
      document.getElementById('triage-result-title').textContent = 'Nexa Prime es tu camino ideal.';
    } else {
      fl.classList.add('recommended'); nx.classList.add('recommended');
      document.getElementById('triage-result-title').textContent = 'Ambos caminos son para ti — explóralos.';
    }
  }

  // CHATBOT
  // ══════════════════════════════════
// CONFIG
// ══════════════════════════════════
const CALENDLY_URL = 'https://calendly.com/drfabricioreyesacosta';
const WA_NUMBER    = '529283989591'; // Alan's number
const WA_BASE      = 'https://wa.me/' + WA_NUMBER;

// ══════════════════════════════════
// STATE
// ══════════════════════════════════
let chatOpen    = false;
let step        = 0;
let userData    = { name: '', path: '', service: '' };
let awaitingInput = null; // 'name' | null

// ══════════════════════════════════
// TOGGLE
// ══════════════════════════════════
function toggleChat() {
  chatOpen = !chatOpen;
  document.getElementById('chat-window').classList.toggle('open', chatOpen);
  document.getElementById('chat-trigger').classList.toggle('open', chatOpen);
  document.getElementById('trigger-icon').textContent = chatOpen ? 'close' : 'chat';
  // Remove notification dot on open
  if (chatOpen) {
    const notif = document.getElementById('chat-notif');
    if (notif) notif.style.display = 'none';
    if (step === 0) startConversation();
  }
}

// ══════════════════════════════════
// MESSAGE HELPERS
// ══════════════════════════════════
function now() {
  return new Date().toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
}

function addMsg(content, type = 'bot', delay = 0) {
  return new Promise(resolve => {
    setTimeout(() => {
      const msgs = document.getElementById('chat-messages');

      if (type === 'typing') {
        const t = document.createElement('div');
        t.className = 'msg bot'; t.id = 'typing-indicator';
        t.innerHTML = `<div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>`;
        msgs.appendChild(t);
        msgs.scrollTop = msgs.scrollHeight;
        resolve(t);
        return;
      }

      // Remove typing if exists
      const typing = document.getElementById('typing-indicator');
      if (typing) typing.remove();

      const div = document.createElement('div');
      div.className = 'msg ' + type;

      if (type === 'bot') {
        div.innerHTML = `<div class="msg-bubble">${content}</div><div class="msg-time">${now()}</div>`;
      } else {
        div.innerHTML = `<div class="msg-bubble">${content}</div><div class="msg-time">${now()}</div>`;
      }

      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
      resolve(div);
    }, delay);
  });
}

function addQuickReplies(options, onSelect) {
  const msgs = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'msg bot'; div.id = 'qr-container';
  div.innerHTML = `<div class="quick-replies">${
    options.map(o => `<button class="qr-btn" onclick="handleQR(this, '${o.value}', qrCallback)">${o.label}</button>`).join('')
  }</div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  window.qrCallback = onSelect;
}

function handleQR(btn, value, callback) {
  // Disable all QR buttons
  document.querySelectorAll('.qr-btn').forEach(b => b.disabled = true);
  btn.style.background = '#2A5D4E';
  btn.style.color = '#f4f1ea';
  btn.style.borderColor = '#2A5D4E';
  // Add user message
  addMsg(btn.textContent, 'user', 100);
  setTimeout(() => callback(value), 400);
}

function addCalendlyButton(service) {
  const msgs = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'msg bot';

  const waMsg = encodeURIComponent(
    `Hola Dr. Alan, me llamo ${userData.name || 'un paciente'} y me gustaría agendar una cita${service ? ' para ' + service : ''}.`
  );

  div.innerHTML = `
    <div class="msg-bubble">Elige la opción que prefieras para agendar:</div>
    <a href="${CALENDLY_URL}" target="_blank" class="calendly-btn">
      <span class="material-symbols-outlined" style="font-size:1rem;">calendar_month</span>
      Ver disponibilidad · Calendly
    </a>
    <a href="${WA_BASE}?text=${waMsg}" target="_blank" class="wa-btn">
      <span class="material-symbols-outlined" style="font-size:1rem;">chat</span>
      Agendar por WhatsApp
    </a>
    <div class="msg-time" style="margin-top:0.25rem;">${now()}</div>
  `;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

// ══════════════════════════════════
// CONVERSATION FLOW
// ══════════════════════════════════
async function startConversation() {
  step = 1;
  // Show typing then greeting
  await addMsg('', 'typing', 600);
  await addMsg('¡Hola! Bienvenido a la clínica del <strong>Dr. Alan Fabricio</strong> 👋', 'bot', 1200);
  await addMsg('', 'typing', 1400);
  await addMsg('Estoy aquí para ayudarte a agendar tu cita. ¿Cómo te llamas?', 'bot', 2200);
  awaitingInput = 'name';
  document.getElementById('chat-input').focus();
}

function sendUserMsg() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';

  if (awaitingInput === 'name') {
    addMsg(text, 'user');
    userData.name = text;
    awaitingInput = null;
    step = 2;
    setTimeout(() => askPath(), 500);
  } else {
    // Generic fallback
    addMsg(text, 'user');
    setTimeout(() => {
      addMsg('Entendido. ¿Te puedo ayudar a agendar una cita con el Dr. Alan? 😊', 'bot', 600);
    }, 400);
  }
}

async function askPath() {
  await addMsg('', 'typing', 400);
  await addMsg(`Mucho gusto, <strong>${userData.name}</strong> 😊`, 'bot', 900);
  await addMsg('', 'typing', 1100);
  await addMsg('¿Qué te trae por aquí hoy?', 'bot', 1800);

  setTimeout(() => {
    addQuickReplies([
      { label: '✨ Mejorar mi apariencia', value: 'facelab' },
      { label: '💚 Optimizar mi salud', value: 'nexa' },
      { label: '🤔 No sé aún', value: 'unsure' }
    ], handlePathSelection);
  }, 2000);
}

async function handlePathSelection(value) {
  userData.path = value;
  step = 3;

  if (value === 'facelab') {
    await addMsg('', 'typing', 500);
    await addMsg('¡Perfecto! <strong>Face Lab</strong> es nuestro servicio de medicina estética de precisión.', 'bot', 1000);
    await addMsg('', 'typing', 1200);
    await addMsg('¿Qué tratamiento te interesa?', 'bot', 1800);
    setTimeout(() => {
      addQuickReplies([
        { label: 'Bótox', value: 'Bótox' },
        { label: 'Rellenos', value: 'Rellenos' },
        { label: 'Endolift Láser', value: 'Endolift Láser' },
        { label: 'Bioestimuladores', value: 'Bioestimuladores' },
        { label: 'No sé aún', value: 'asesoría facial' }
      ], handleServiceSelection);
    }, 2000);

  } else if (value === 'nexa') {
    await addMsg('', 'typing', 500);
    await addMsg('Excelente. <strong>Nexa Prime</strong> es nuestro programa médico integral de longevidad y optimización de salud.', 'bot', 1000);
    await addMsg('', 'typing', 1200);
    await addMsg('Es un programa de acceso selectivo. La primera consulta es una evaluación completa para ver si eres candidato ideal.', 'bot', 1900);
    setTimeout(() => goToBooking('Nexa Prime'), 2200);

  } else {
    await addMsg('', 'typing', 500);
    await addMsg('No hay problema 😊 Tenemos dos caminos principales:', 'bot', 1000);
    await addMsg('', 'typing', 1200);
    await addMsg('<strong>Face Lab</strong> — medicina estética: bótox, rellenos, Endolift y más.<br><strong>Nexa Prime</strong> — optimización integral de salud y longevidad.', 'bot', 1800);
    await addMsg('', 'typing', 2100);
    await addMsg('El Dr. Alan puede orientarte personalmente. Te recomiendo agendar una consulta inicial.', 'bot', 2700);
    setTimeout(() => goToBooking('consulta inicial'), 3000);
  }
}

async function handleServiceSelection(value) {
  userData.service = value;
  step = 4;
  await addMsg('', 'typing', 400);
  await addMsg(`Perfecto — <strong>${value}</strong>. El Dr. Alan tiene experiencia especializada en este tratamiento.`, 'bot', 900);
  setTimeout(() => goToBooking(value), 1200);
}

async function goToBooking(service) {
  await addMsg('', 'typing', 400);
  await addMsg('Para agendar tu cita puedes elegir el horario directamente en nuestro calendario, o escribirnos por WhatsApp si prefieres atención personalizada.', 'bot', 1000);
  setTimeout(() => {
    addCalendlyButton(service);
    // Disable input — booking handled via buttons
    document.getElementById('chat-input').placeholder = 'Usa los botones de arriba para agendar';
    document.getElementById('chat-input').disabled = true;
    document.getElementById('chat-send').disabled = true;
  }, 1400);
}

</script>

</body>
</html>
